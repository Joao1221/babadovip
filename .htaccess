RewriteEngine On
Options -Indexes

# Canonical do dominio publico (HTTPS + WWW) sem afetar localhost
RewriteCond %{HTTP_HOST} ^(?:www\.)?babadovip\.(?:com\.br|free\.nf)$ [NC]
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\.babadovip\.com\.br$ [NC]
RewriteRule ^ https://www.babadovip.com.br%{REQUEST_URI} [R=301,L]

# Evita URL /public/... exposta na barra (corrige /public/index.php)
RewriteCond %{THE_REQUEST} \s/+public/index\.php(?:[?\s]|$) [NC]
RewriteRule ^public/index\.php$ / [R=301,L]
RewriteCond %{THE_REQUEST} \s/+public/([^\s?]*) [NC]
RewriteRule ^public/(.+)$ /$1 [R=301,L]

# Protege pastas e arquivos sensiveis quando o projeto inteiro fica em public_html
RewriteRule ^(?:app|database|storage)(?:/|$) - [F,L,NC]
RewriteRule ^(?:\.env|\.env\.web|README\.md|composer\.(?:json|lock)|phpunit\.xml)$ - [F,L,NC]

# Arquivos estaticos publicos
RewriteRule ^assets/(.*)$ public/assets/$1 [L,NC,QSA]
RewriteRule ^img/(.*)$ public/img/$1 [L,NC,QSA]
RewriteRule ^uploads/(.*)$ public/uploads/$1 [L,NC,QSA]
RewriteRule ^(favicon\.ico|robots\.txt)$ public/$1 [L,NC,QSA]

# Front-controller
RewriteRule ^$ public/index.php [L,QSA]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ public/index.php [L,QSA]
