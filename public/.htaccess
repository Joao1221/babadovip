<IfModule mod_rewrite.c>
    RewriteEngine On

    # Canonical em producao: HTTPS + WWW
    RewriteCond %{HTTP_HOST} ^(babadovip\.com\.br|www\.babadovip\.com\.br)$ [NC]
    RewriteCond %{HTTPS} !=on [OR]
    RewriteCond %{HTTP_HOST} !^www\.babadovip\.com\.br$ [NC]
    RewriteRule ^ https://www.babadovip.com.br%{REQUEST_URI} [R=301,L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>
